@page "/activities"
@attribute [StreamRendering(true)]

<PageTitle>Activities</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">My Activities</MudText>

@if (activities == null)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
        <MudProgressCircular Size="Size.Large" Indeterminate="true" />
        <MudText Typo="Typo.body1" Class="mt-4">Loading activities...</MudText>
    </MudStack>
}
else if (!activities.Any())
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-8">
        <MudIcon Icon="@Icons.Material.Filled.Route" Size="Size.Large" Color="Color.Info" />
        <MudText Typo="Typo.h5" Class="mt-4">No activities yet</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            Import your first activity file to get started!
        </MudText>
        <MudButton Variant="Variant.Filled"
                  Color="Color.Primary"
                  StartIcon="@Icons.Material.Filled.CloudUpload"
                  Href="/import"
                  Class="mt-4">
            Import File
        </MudButton>
    </MudStack>
}
else
{
    <MudStack Spacing="3" Class="mb-4">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="searchText"
                             Label="Search activities"
                             Variant="Variant.Outlined"
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.Search"
                             Immediate="true"
                             DebounceInterval="300"
                             Class="flex-grow-1" />
                <MudSelect @bind-Value="selectedActivityType"
                          Label="Activity Type"
                          Variant="Variant.Outlined"
                          Clearable="true"
                          Class="flex-shrink-0"
                          Style="min-width: 200px;">
                    <MudSelectItem Value="@("")">All Activities</MudSelectItem>
                    @foreach (var type in GetActivityTypes())
                    {
                        <MudSelectItem Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
        </MudPaper>
    </MudStack>

    @if (selectedIds.Count == 2)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.MergeType">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudText Typo="Typo.body2">2 activities selected — ready to merge</MudText>
                <MudButton Variant="Variant.Filled"
                          Color="Color.Secondary"
                          Size="Size.Small"
                          StartIcon="@Icons.Material.Filled.MergeType"
                          OnClick="NavigateToMerge">
                    Merge Selected
                </MudButton>
                <MudButton Variant="Variant.Text"
                          Color="Color.Default"
                          Size="Size.Small"
                          OnClick="@(() => selectedIds.Clear())">
                    Clear
                </MudButton>
            </MudStack>
        </MudAlert>
    }

    <MudDataGrid T="ActivitySummary"
                Items="FilteredActivities"
                SortMode="SortMode.None"
                Filterable="false"
                Striped="true"
                Bordered="true"
                Dense="true"
                Hover="true"
                Class="mb-4">
        <Columns>
            <TemplateColumn Title="" CellStyle="width:40px">
                <CellTemplate>
                    @{
                        var itemId = context.Item.Id;
                        var isChecked = selectedIds.Contains(itemId);
                    }
                    <MudCheckBox Value="@isChecked"
                                ValueChanged="@((bool v) => ToggleSelection(itemId, v))"
                                Disabled="@(!isChecked && selectedIds.Count >= 2)"
                                Size="Size.Small" />
                </CellTemplate>
            </TemplateColumn>

            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudButton Variant="Variant.Text"
                              Color="Color.Primary"
                              Size="Size.Small"
                              Href="@($"/activities/{context.Item.Id}")">
                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                        View
                    </MudButton>
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.StartDateTime" Title="Date">
                <CellTemplate>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2">@context.Item.StartDateTime.ToString("MMM dd, yyyy")</MudText>
                        <MudText Typo="Typo.caption">@context.Item.StartDateTime.ToString("HH:mm")</MudText>
                    </MudStack>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.Title" Title="Activity">
                <CellTemplate>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2">@context.Item.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Info">@context.Item.ActivityType</MudText>
                    </MudStack>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.DistanceMeters" Title="Distance">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@FormatDistance(context.Item.DistanceMeters)</MudText>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.ElevationGainMeters" Title="Elevation">
                <CellTemplate>
                    <MudText Typo="Typo.body2">
                        <MudIcon Icon="@Icons.Material.Filled.Terrain" Size="Size.Small" />
                        +@FormatElevation(context.Item.ElevationGainMeters)
                    </MudText>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.AverageSpeedMs" Title="Avg Speed">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@FormatSpeed(context.Item.AverageSpeedMs)</MudText>
                </CellTemplate>
            </PropertyColumn>

            <PropertyColumn Property="x => x.EndDateTime.Subtract(x.StartDateTime)" Title="Duration">
                <CellTemplate>
                    <MudText Typo="Typo.body2">@FormatDuration(context.Item.StartDateTime, context.Item.EndDateTime)</MudText>
                </CellTemplate>
            </PropertyColumn>
        </Columns>
    </MudDataGrid>

    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @FilteredActivities.Count() of @activities.Count activity@(activities.Count == 1 ? "" : "ies")
        </MudText>
        <MudButton Variant="Variant.Outlined"
                  Color="Color.Primary"
                  StartIcon="@Icons.Material.Filled.CloudUpload"
                  Href="/import">
            Import File
        </MudButton>
    </MudStack>
}

@inject webapp.Services.ActivityStore ActivityStore
@inject webapp.Services.ActivityApiClient ActivityApiClient
@inject NavigationManager NavigationManager

@code {
    private List<webapp.Services.ActivitySummary>? activities;
    private string searchText = string.Empty;
    private string selectedActivityType = string.Empty;
    private readonly HashSet<Guid> selectedIds = new();

    private void ToggleSelection(Guid id, bool selected)
    {
        if (selected)
            selectedIds.Add(id);
        else
            selectedIds.Remove(id);
    }

    private void NavigateToMerge()
    {
        var ids = selectedIds.ToArray();
        NavigationManager.NavigateTo($"/merge?a={ids[0]}&b={ids[1]}");
    }

    private IEnumerable<webapp.Services.ActivitySummary> FilteredActivities
    {
        get
        {
            if (activities == null) return Enumerable.Empty<webapp.Services.ActivitySummary>();

            var filtered = activities.AsEnumerable();

            // Apply text search filter
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                filtered = filtered.Where(a => 
                    a.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    (a.ActivityType?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            // Apply activity type filter
            if (!string.IsNullOrWhiteSpace(selectedActivityType))
            {
                filtered = filtered.Where(a => 
                    a.ActivityType != null && 
                    a.ActivityType.Equals(selectedActivityType, StringComparison.OrdinalIgnoreCase));
            }

            return filtered;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadActivitiesAsync();
    }

    private async Task LoadActivitiesAsync()
    {
        var apiActivities = await ActivityApiClient.GetAllActivitiesAsync();
        
        // Merge API results into store: preserve cached TrackData for unchanged activities
        foreach (var a in apiActivities)
        {
            var cached = ActivityStore.GetById(a.Id);
            if (cached?.TrackData != null)
            {
                a.TrackData = cached.TrackData;
                a.TrackCoordinates = cached.TrackCoordinates;
            }
            ActivityStore.AddOrUpdate(a);
        }
        
        // Remove from store any activities no longer in the DB
        var apiIds = apiActivities.Select(a => a.Id).ToHashSet();
        foreach (var storeActivity in ActivityStore.Activities.ToList())
        {
            if (!apiIds.Contains(storeActivity.Id))
                ActivityStore.Remove(storeActivity.Id);
        }
        
        activities = ActivityStore.Activities.OrderByDescending(a => a.StartDateTime).ToList();
    }

    private IEnumerable<string> GetActivityTypes()
    {
        if (activities == null) return Enumerable.Empty<string>();
        return activities
            .Where(a => !string.IsNullOrWhiteSpace(a.ActivityType))
            .Select(a => a.ActivityType!)
            .Distinct()
            .OrderBy(t => t);
    }

    private string FormatDistance(double meters)
    {
        if (meters >= 1000)
        {
            return $"{meters / 1000:F1} km";
        }
        return $"{meters:F0} m";
    }

    private string FormatElevation(double meters)
    {
        return $"{meters:F0} m";
    }

    private string FormatSpeed(double metersPerSecond)
    {
        var kmh = metersPerSecond * 3.6;
        return $"{kmh:F1} km/h";
    }

    private string FormatDuration(DateTime start, DateTime end)
    {
        var duration = end - start;
        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours}:{duration.Minutes:D2}:{duration.Seconds:D2}";
        }
        else if (duration.TotalMinutes >= 1)
        {
            return $"{(int)duration.TotalMinutes}:{duration.Seconds:D2}";
        }
        else
        {
            return $"{duration.Seconds} sec";
        }
    }

}